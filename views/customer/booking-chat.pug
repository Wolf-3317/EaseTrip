extends ../layouts/main

block content
  .container
    .dashboard
      aside.dashboard-sidebar
        nav
          a.sidebar-nav-item(href="/customer/dashboard")
            i.fas.fa-th-large
            span Dashboard
          a.sidebar-nav-item(href="/customer/trips")
            i.fas.fa-suitcase
            span My Trips
          a.sidebar-nav-item.active(href="/customer/bookings")
            i.fas.fa-calendar-check
            span Bookings
          a.sidebar-nav-item(href="/customer/favorites")
            i.fas.fa-heart
            span Favorites
          a.sidebar-nav-item(href="/customer/reviews")
            i.fas.fa-star
            span My Reviews
          a.sidebar-nav-item(href="/customer/inbox")
            i.fas.fa-envelope
            span Inbox
          a.sidebar-nav-item(href="/profile")
            i.fas.fa-user-circle
            span Profile
      
      main.dashboard-main
        .dashboard-header
          .flex.items-center.gap-4
            a.btn.btn-secondary(href="/customer/bookings")
              i.fas.fa-arrow-left
            div
              h1.dashboard-title Chat with #{otherUser.name}
              p.dashboard-subtitle 
                | About: #{booking.listing_title}
        
        //- Booking Info Card
        .dashboard-card(style="margin-bottom: 1rem;")
          .dashboard-card-body
            .flex.items-center.gap-4(style="flex-wrap: wrap;")
              img(src=booking.listing_image || 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=100' alt=booking.listing_title style="width: 80px; height: 60px; object-fit: cover; border-radius: var(--radius-md);")
              div(style="flex: 1; min-width: 200px;")
                h4(style="font-weight: 600; color: var(--gray-900);")= booking.listing_title
                p(style="font-size: 0.875rem; color: var(--gray-500);")
                  i.fas.fa-calendar(style="margin-right: 0.25rem;")
                  | #{new Date(booking.check_in).toLocaleDateString('en-MY')} - #{new Date(booking.check_out).toLocaleDateString('en-MY')}
              span.badge.badge-success= booking.status
        
        .dashboard-card(style="margin-bottom: 1.5rem;")
          .dashboard-card-body
            .conversation-messages#conversationMessages(style="max-height: 350px; overflow-y: auto; padding: 1rem;")
              if conversation && conversation.length > 0
                each msg in conversation
                  .message-bubble(style=`display: flex; margin-bottom: 1rem; ${msg.sender_id === user.id ? 'justify-content: flex-end;' : 'justify-content: flex-start;'}`)
                    .message-content(style=`max-width: 70%; padding: 1rem; border-radius: var(--radius-lg); ${msg.sender_id === user.id ? 'background: var(--primary-gradient); color: white;' : 'background: var(--gray-100); color: var(--gray-900);'}`)
                      p(style="line-height: 1.5;")= msg.content
                      p(style=`font-size: 0.75rem; margin-top: 0.5rem; ${msg.sender_id === user.id ? 'color: rgba(255,255,255,0.7);' : 'color: var(--gray-400);'}`)= new Date(msg.created_at).toLocaleString('en-MY')
              else
                .empty-state(style="padding: 2rem;")
                  i.fas.fa-comments(style="font-size: 2rem; color: var(--gray-300); margin-bottom: 1rem;")
                  p(style="color: var(--gray-500);") Start the conversation with your host!
        
        //- Reply Form
        .dashboard-card
          .dashboard-card-body
            form(action="/customer/inbox/send" method="POST")
              input(type="hidden" name="receiver_id" value=otherUser.id)
              input(type="hidden" name="booking_id" value=booking.id)
              .flex.gap-3.items-end
                .form-group(style="flex: 1; margin-bottom: 0;")
                  textarea.form-input(name="content" rows="2" placeholder="Type your message..." required style="resize: none;")
                button.btn.btn-primary(type="submit" style="height: 52px;")
                  i.fas.fa-paper-plane
              p(style="font-size: 0.75rem; color: var(--gray-400); margin-top: 0.5rem;")
                i.fas.fa-info-circle(style="margin-right: 0.25rem;")
                | Chat will end once you submit a review

block scripts
  script.
    // Scroll to bottom of conversation
    const messages = document.getElementById('conversationMessages');
    if (messages) {
      messages.scrollTop = messages.scrollHeight;
    }
