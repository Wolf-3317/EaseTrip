extends ../layouts/main

block content
  .container
    .dashboard
      aside.dashboard-sidebar
        nav
          a.sidebar-nav-item(href="/customer/dashboard")
            i.fas.fa-th-large
            span Dashboard
          a.sidebar-nav-item(href="/customer/trips")
            i.fas.fa-suitcase
            span My Trips
          a.sidebar-nav-item(href="/customer/bookings")
            i.fas.fa-calendar-check
            span Bookings
          a.sidebar-nav-item(href="/customer/favorites")
            i.fas.fa-heart
            span Favorites
          a.sidebar-nav-item(href="/customer/reviews")
            i.fas.fa-star
            span My Reviews
          a.sidebar-nav-item.active(href="/customer/inbox")
            i.fas.fa-envelope
            span Inbox
          a.sidebar-nav-item(href="/profile")
            i.fas.fa-user-circle
            span Profile
      
      main.dashboard-main
        .dashboard-header
          .flex.items-center.gap-4
            a.btn.btn-secondary(href="/customer/inbox")
              i.fas.fa-arrow-left
            div
              h1.dashboard-title Conversation with #{otherUser.name}
              p.dashboard-subtitle 
                span.badge(class=otherUser.role === 'host' ? 'badge-success' : 'badge-info')= otherUser.role
        
        .dashboard-card(style="margin-bottom: 1.5rem;")
          .dashboard-card-body
            .conversation-messages#conversationMessages(style="max-height: 400px; overflow-y: auto; padding: 1rem;")
              if conversation && conversation.length > 0
                each msg in conversation
                  .message-bubble(style=`display: flex; margin-bottom: 1rem; ${msg.sender_id === user.id ? 'justify-content: flex-end;' : 'justify-content: flex-start;'}`)
                    .message-content(style=`max-width: 70%; padding: 1rem; border-radius: var(--radius-lg); ${msg.sender_id === user.id ? 'background: var(--primary-gradient); color: white;' : 'background: var(--gray-100); color: var(--gray-900);'}`)
                      p(style="line-height: 1.5;")= msg.content
                      p(style=`font-size: 0.75rem; margin-top: 0.5rem; ${msg.sender_id === user.id ? 'color: rgba(255,255,255,0.7);' : 'color: var(--gray-400);'}`)= new Date(msg.created_at).toLocaleString('en-MY')
              else
                .empty-state(style="padding: 2rem;")
                  p(style="color: var(--gray-500);") No messages yet. Start the conversation!
        
        //- Reply Form
        .dashboard-card
          .dashboard-card-body
            form(action="/customer/inbox/send" method="POST")
              input(type="hidden" name="receiver_id" value=otherUser.id)
              .flex.gap-3.items-end
                .form-group(style="flex: 1; margin-bottom: 0;")
                  textarea.form-input(name="content" rows="2" placeholder="Type your message..." required style="resize: none;")
                button.btn.btn-primary(type="submit" style="height: 52px;")
                  i.fas.fa-paper-plane

block scripts
  script.
    // Scroll to bottom of conversation
    const messages = document.getElementById('conversationMessages');
    if (messages) {
      messages.scrollTop = messages.scrollHeight;
    }
