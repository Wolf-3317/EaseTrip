extends ../layouts/main

block content
  .container
    .dashboard
      aside.dashboard-sidebar
        nav
          a.sidebar-nav-item(href="/admin/dashboard")
            i.fas.fa-tachometer-alt
            span Dashboard
          a.sidebar-nav-item(href="/admin/users")
            i.fas.fa-users
            span Users
          a.sidebar-nav-item.active(href="/admin/listings")
            i.fas.fa-home
            span Listings
          a.sidebar-nav-item(href="/admin/reports")
            i.fas.fa-flag
            span Reports
          a.sidebar-nav-item(href="/admin/weather")
            i.fas.fa-cloud-sun
            span Weather
      
      main.dashboard-main
        .dashboard-header
          h1.dashboard-title Manage Listings
          p.dashboard-subtitle Review and moderate all listings
        
        //- Filters
        .flex.gap-2.mb-6
          a.btn(href="/admin/listings" class=!filters.status ? 'btn-primary' : 'btn-secondary') All
          a.btn(href="/admin/listings?status=pending" class=filters.status === 'pending' ? 'btn-primary' : 'btn-secondary') Pending
          a.btn(href="/admin/listings?status=active" class=filters.status === 'active' ? 'btn-primary' : 'btn-secondary') Active
          a.btn(href="/admin/listings?status=delisted" class=filters.status === 'delisted' ? 'btn-primary' : 'btn-secondary') Delisted
        
        //- Listings Table
        .dashboard-card
          .dashboard-card-body
            if listings && listings.length > 0
              .table-responsive
                table.table
                  thead
                    tr
                      th Listing
                      th Host
                      th City
                      th Price
                      th Status
                      th Actions
                  tbody
                    each listing in listings
                      tr
                        td
                          .flex.items-center.gap-3
                            img(src=listing.primary_image || 'https://via.placeholder.com/60' style="width: 60px; height: 45px; object-fit: cover; border-radius: var(--radius-md);")
                            div
                              p(style="font-weight: 600;")= listing.title
                              p(style="font-size: 0.75rem; color: var(--gray-500);")= listing.type
                        td
                          p= listing.host_name
                          p(style="font-size: 0.75rem; color: var(--gray-500);")= listing.host_email
                        td= listing.city
                        td RM #{listing.price}
                        td
                          span.badge(class=`badge-${listing.status === 'active' ? 'success' : listing.status === 'pending' ? 'warning' : 'error'}`)= listing.status
                        td
                          .flex.gap-2
                            a.btn.btn-sm.btn-secondary(href=`/listings/${listing.id}` target="_blank")
                              i.fas.fa-eye
                            if listing.status === 'pending'
                              form(action=`/admin/listings/${listing.id}/status` method="POST" style="display: inline;")
                                input(type="hidden" name="status" value="active")
                                button.btn.btn-sm.btn-primary(type="submit" title="Approve")
                                  i.fas.fa-check
                              form(action=`/admin/listings/${listing.id}/status` method="POST" style="display: inline;")
                                input(type="hidden" name="status" value="rejected")
                                button.btn.btn-sm.btn-outline(type="submit" style="color: var(--error); border-color: var(--error);" title="Reject")
                                  i.fas.fa-times
                            if listing.status === 'active'
                              form(action=`/admin/listings/${listing.id}/feature` method="POST" style="display: inline;")
                                input(type="hidden" name="featured" value=listing.is_featured ? 'false' : 'true')
                                button.btn.btn-sm.btn-outline(type="submit" title=listing.is_featured ? 'Unfeature' : 'Feature' style=listing.is_featured ? 'color: var(--accent-gold); border-color: var(--accent-gold);' : '')
                                  i.fas.fa-star
                              form(action=`/admin/listings/${listing.id}/status` method="POST" style="display: inline;")
                                input(type="hidden" name="status" value="delisted")
                                button.btn.btn-sm.btn-outline(type="submit" style="color: var(--error); border-color: var(--error);" title="Delist")
                                  i.fas.fa-ban
            else
              .empty-state
                p(style="color: var(--gray-500);") No listings found
